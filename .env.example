# 공사비닷컴 클라우드 연동 환경변수 (샘플)
# 주의: 이 파일은 .env.example 이며, 실제 키값은 절대 GitHub에 올리지 마세요.
# 실제 서버 배포 시에는 이 파일을 복사하여 .env 파일을 만들고 실제 값을 입력하세요.

# 1. Cloud Storage Configuration (AWS S3, R2, Naver Cloud 등)
STORAGE_PROVIDER=s3
STORAGE_BASE_URL=https://cdn.gongsabi.com/uploads
STORAGE_BUCKET=gongsabi-bucket-prod
STORAGE_REGION=ap-northeast-2
STORAGE_ACCESS_KEY=your_access_key_here
STORAGE_SECRET_KEY=your_secret_key_here

# 2. Backend API Configuration (검색, 내역서, 게시판 등 데이터 통신용)
API_BASE_URL=https://api.gongsabi.com/v1
API_TIMEOUT=5000

# 3. Database Configuration (실제 백엔드 서버에서만 사용)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=gongsabi_db
DB_USER=gongsabi_user
DB_PASSWORD=your_secure_password

# 4. App Environment
NODE_ENV=production
APP_DEBUG=false
